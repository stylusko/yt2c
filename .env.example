# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Storage directory for temp files and outputs
STORAGE_DIR=/tmp/yt2c-storage

# Optional: Cloudflare R2 (S3-compatible)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=yt2c-outputs
# R2_PUBLIC_URL=

# Optional: Supabase (short share URLs)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...

# Fal.ai (Flux image generation — used by article → card news feature)
# FAL_KEY=

# Server
PORT=3000
