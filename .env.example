# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Storage directory for temp files and outputs
STORAGE_DIR=/tmp/yt2c-storage

# Optional: Cloudflare R2 (S3-compatible)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=yt2c-outputs
# R2_PUBLIC_URL=

# Optional: Supabase (short share URLs)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...

# Fal.ai (Flux image generation — used by article → card news feature)
# FAL_KEY=

# Jina Reader — 유료 기능 활성화 (무료 1M 토큰부터 시작, https://jina.ai)
# 설정 시 SPA iframe 처리 + JS 렌더링 긴 타임아웃 자동 적용.
# 배민·Notion 같은 SPA 사이트 커버리지 대폭 향상.
# JINA_API_KEY=

# Server
PORT=3000
